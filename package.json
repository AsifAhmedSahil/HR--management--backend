{
  "name": "hr-management-backend",
  "version": "1.0.0",
  "description": "HR Management System - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed:run": "knex seed:run --knexfile knexfile.ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "express": "^4.18.2",
    "knex": "^3.3.0",
    "pg": "^8.11.5",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^6.0.0",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "prettier": "^3.2.5",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "supertest": "^7.0.0",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
